# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*.log
/tmp/

# Keep the directories
!/log/.keep
!/tmp/.keep
!/tmp/pids/
!/tmp/pids/.keep
!/tmp/storage/
!/tmp/storage/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*.sqlite3
/storage/*.sqlite3-journal
/storage/*.sqlite3-shm
/storage/*.sqlite3-wal

# Ignore node_modules
/node_modules
/vendor/bundle

# Ignore public assets (if using Sprockets/Propshaft)
/public/assets

# Ignore key files for decrypting credentials.
/config/master.key
/config/credentials/*.key

# IDE specific
.idea/
.vscode/
*.swp
*.swo

# OS specific
.DS_Store
.AppleDouble
.LSOverride
Icon


# Custom project ignore
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-shm
/db/*.sqlite3-wal
